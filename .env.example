# Copy this file to `.env` and fill in your own values.
# Never commit your real .env file.

# Required: your Ollama Cloud API key (https://ollama.com/settings/keys)
# Gemma 4 is served here as `gemma4:cloud`, not via Groq (Groq doesn't
# currently host Gemma 4).
OLLAMA_API_KEY=

# Optional overrides — sensible defaults are already set in model/config.py
# OLLAMA_HOST=https://ollama.com
# OLLAMA_MODEL=gemma4:cloud
# ASR_MODEL_ID=ai4bharat/indic-conformer-600m-multilingual
# ASR_DECODING=ctc
# TRANSLATION_INDIC_EN_MODEL_ID=ai4bharat/indictrans2-indic-en-dist-200M
# TRANSLATION_EN_INDIC_MODEL_ID=ai4bharat/indictrans2-en-indic-dist-200M
# TTS_MODEL_ID=ai4bharat/indic-parler-tts
# MAX_HISTORY_TURNS=6
# MODEL_DEVICE=auto
